    "openai-api": {
      "provider": "openai",
      "endpoint": "https://api.openai.com/v1",
      "auth": {"type": "env", "var": "OPENAI_API_KEY"},
      "headers": {},
      "models": ["gpt-4o", "gpt-4o-mini"]
