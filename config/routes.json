      "auth": {"type": "static", "value": "ollama"},
      "headers": {},
      "models": ["qwopus3.6-27b-v2", "devstral-small-2:24b", "qwen3-coder:latest", "glm-flash", "gemma4-26b-a4b"]
    },
    "hivemind-gateway": {
      "provider": "openai-compatible",
      "endpoint": "http://127.0.0.1:8400/v1",
