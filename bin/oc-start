#!/usr/bin/env bash
# super-oc-cli: Start OpenClaude with local LLM in tmux
# Config-driven — all settings in ~/.super-oc/config.json
#
# Usage: oc-start [model-alias] [--bare] [--no-mcp] [--agent NAME] [--pipeline] [--dry-run]
#
# Modes:
#   Interactive (default):  Single openclaude session with watchdog restart
#   Pipeline (--pipeline):  Multi-phase agentic loop via oc-engine

set -uo pipefail

# ── Locate and source config loader ─────────────────────────────────────────
OC_HOME="${SUPER_OC_HOME:-$HOME/.super-oc}"

# Find lib dir: installed location first, then repo checkout
if [[ -f "$OC_HOME/lib/oc-config.sh" ]]; then
    source "$OC_HOME/lib/oc-config.sh"
elif [[ -f "$(dirname "${BASH_SOURCE[0]}")/../lib/oc-config.sh" ]]; then
    source "$(dirname "${BASH_SOURCE[0]}")/../lib/oc-config.sh"
else
    echo "FATAL: Cannot find oc-config.sh — run oc-install.sh first"
    exit 1
fi

# ── Parse arguments ──────────────────────────────────────────────────────────
MODEL="${1:-}"
SESSION="$(_oc_cfg_get tmux_session)"
USE_BARE=false
USE_MCP=true
USE_PIPELINE=false
USE_DRY_RUN=false
AGENT_NAME=""

for arg in "$@"; do
    case "$arg" in
        --bare)     USE_BARE=true ;;
        --no-mcp)   USE_MCP=false ;;
        --pipeline) USE_PIPELINE=true ;;
        --dry-run)  USE_DRY_RUN=true ;;
    esac
done

# Parse --agent NAME (needs next-arg lookahead)
_args=("$@")
for ((i=0; i<${#_args[@]}; i++)); do
    if [[ "${_args[$i]}" == "--agent" ]]; then
        AGENT_NAME="${_args[$((i+1))]:-}"
        break
    fi
done

# ── Resolve model ────────────────────────────────────────────────────────────
# Default from config if not specified or if a flag was passed as first arg
[[ -z "$MODEL" || "$MODEL" == --* ]] && MODEL="$(_oc_cfg_get model_default)"

# Try config aliases first
RESOLVED=$(_oc_cfg_resolve_alias "$MODEL")
[[ -n "$RESOLVED" ]] && MODEL="$RESOLVED"

OC_LIB_DIR="$(_oc_cfg_lib_dir)"

# Try route library for richer alias resolution
if [[ -f "$OC_LIB_DIR/oc-routes.sh" ]]; then
    source "$OC_LIB_DIR/oc-routes.sh"
    oc_route_init || echo "[!] Route init failed — using config aliases"
    MODEL=$(oc_route_resolve_alias "$MODEL")
    [[ "$MODEL" == --* ]] && MODEL="$(_oc_cfg_get model_default)"
fi

OLLAMA_PORT="$(_oc_cfg_get ollama_port)"
GATEWAY_PORT="$(_oc_cfg_get gateway_port)"

tmux kill-session -t "$SESSION" 2>/dev/null

# ── Model switching ─────────────────────────────────────────────────────────
_switch_model() {
    local target="$1"
    local script
    script=$(_oc_cfg_model_script "$target")

    if [[ -n "$script" && -f "$script" ]]; then
        echo "Starting $target via custom script..."
        bash "$script"
    else
        echo "Model $target — assuming already loaded in Ollama"
    fi
}

if declare -f oc_route_with_fallback &>/dev/null; then
    echo "Resolving route for $MODEL..."
    oc_route_with_fallback "$MODEL" || {
        echo "[!] Route resolution failed — falling back to direct Ollama"
        RUNNING_MODEL=$(curl -sf "http://127.0.0.1:${OLLAMA_PORT}/v1/models" 2>/dev/null \
            | jq -r '.data[0].id // empty' 2>/dev/null || echo "")
        if [[ "$RUNNING_MODEL" != "$MODEL" ]]; then
            echo "Switching model: $RUNNING_MODEL → $MODEL"
            PID=$(ss -ltnp 2>/dev/null | grep ":${OLLAMA_PORT}" | grep -oP 'pid=\K[0-9]+' | head -1)
            [[ -n "$PID" ]] && kill -9 "$PID" 2>/dev/null && sleep 2
            _switch_model "$MODEL"
        fi
    }
else
    RUNNING_MODEL=$(curl -sf "http://127.0.0.1:${OLLAMA_PORT}/v1/models" 2>/dev/null \
        | jq -r '.data[0].id // empty' 2>/dev/null || echo "")
    if [[ "$RUNNING_MODEL" != "$MODEL" ]]; then
        echo "Switching model: $RUNNING_MODEL → $MODEL"
        PID=$(ss -ltnp 2>/dev/null | grep ":${OLLAMA_PORT}" | grep -oP 'pid=\K[0-9]+' | head -1)
        [[ -n "$PID" ]] && kill -9 "$PID" 2>/dev/null && sleep 2
        _switch_model "$MODEL"
    fi
fi

# ── MCP servers (config-driven) ─────────────────────────────────────────────
if [[ "$USE_MCP" == true ]] && _oc_cfg_is_true "mcp_enabled"; then
    [[ -f "$HOME/.bw-session" ]] && export BW_SESSION="$(cat "$HOME/.bw-session")"

    # Start configured MCP servers
    MCP_SERVERS=$(_oc_cfg_mcp_servers)
    MCP_COUNT=$(echo "$MCP_SERVERS" | jq 'length' 2>/dev/null || echo 0)

    for ((i=0; i<MCP_COUNT; i++)); do
        SRV_NAME=$(echo "$MCP_SERVERS" | jq -r ".[$i].name // empty")
        SRV_HEALTH=$(echo "$MCP_SERVERS" | jq -r ".[$i].health_url // empty")
        SRV_START=$(echo "$MCP_SERVERS" | jq -r ".[$i].start_cmd // empty")
        SRV_STOP=$(echo "$MCP_SERVERS" | jq -r ".[$i].stop_cmd // empty")

        [[ -z "$SRV_NAME" || -z "$SRV_START" ]] && continue

        if [[ -n "$SRV_HEALTH" ]] && curl -sf "$SRV_HEALTH" &>/dev/null; then
            echo "[+] $SRV_NAME already running"
        else
            echo "Starting $SRV_NAME..."
            eval "$SRV_START" || echo "[!] $SRV_NAME failed to start"
        fi
    done
fi

# ── Build OC flags ───────────────────────────────────────────────────────────
OC_FLAGS=""
[[ "$USE_BARE" == true ]] && OC_FLAGS="--bare"

MCP_CONFIG="$(_oc_cfg_get mcp_config)"
if [[ "$USE_MCP" == true ]] && [[ -f "$MCP_CONFIG" ]]; then
    OC_FLAGS="$OC_FLAGS --mcp-config $MCP_CONFIG"
fi

EXTRA_FLAGS="$(_oc_cfg_get extra_oc_flags)"
[[ -n "$EXTRA_FLAGS" ]] && OC_FLAGS="$OC_FLAGS $EXTRA_FLAGS"

# Add extra dirs
while IFS= read -r dir; do
    [[ -n "$dir" && -d "$dir" ]] && OC_FLAGS="$OC_FLAGS --add-dir $dir"
done < <(_oc_cfg_extra_dirs)

if _oc_cfg_is_true "skip_permissions"; then
    OC_FLAGS="$OC_FLAGS --dangerously-skip-permissions"
fi

# ── Build launch script ─────────────────────────────────────────────────────
WORK_DIR="$(_oc_cfg_work_dir)"
NODE_MAX_OLD="$(_oc_cfg_get node_max_old_space)"
NODE_SEMI="$(_oc_cfg_get node_semi_space)"
UV_THREADS="$(_oc_cfg_get uv_threadpool_size)"
MAX_CONC="$(_oc_cfg_get max_tool_concurrency)"
MAX_TOKENS="$(_oc_cfg_get max_output_tokens)"
CTX_WINDOW="$(_oc_cfg_get context_window)"
COMPACT_THRESH="$(_oc_cfg_get auto_compact_threshold)"

cat > /tmp/.oc-launch.sh << 'EOF'
export CLAUDE_SESSION_ID="oc-$(tty 2>/dev/null | tr '/' '-' | sed 's/^-//')-$$"
export CLAUDE_CODE_USE_OPENAI=1
export CLAUDE_CODE_PROVIDER_PROFILE_ENV_APPLIED=1
export OPENAI_API_KEY=ollama
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$HOME/.npm-global/bin:$HOME/bin:$PATH"
[ -f "$HOME/.bw-session" ] && export BW_SESSION="$(cat "$HOME/.bw-session")"
EOF

# Inject resolved config values
cat >> /tmp/.oc-launch.sh << ENVBLOCK
export CLAUDE_CODE_MAX_OUTPUT_TOKENS=${MAX_TOKENS}
export NODE_OPTIONS="--max-old-space-size=${NODE_MAX_OLD} --max-semi-space-size=${NODE_SEMI}"
export UV_THREADPOOL_SIZE=${UV_THREADS}
export CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY=${MAX_CONC}
export CLAUDE_CODE_OPENAI_FALLBACK_CONTEXT_WINDOW=${CTX_WINDOW}
export CLAUDE_CODE_AUTO_COMPACT_THRESHOLD=${COMPACT_THRESH}
cd ${WORK_DIR} 2>/dev/null || { mkdir -p ${WORK_DIR} && cd ${WORK_DIR}; }
ENVBLOCK

# ── Resolve gateway + export env vars ───────────────────────────────────────
if [[ -z "${OPENAI_BASE_URL:-}" ]]; then
    if _oc_cfg_is_true "gateway_enabled" && curl -sf --max-time 2 "http://127.0.0.1:${GATEWAY_PORT}/health" &>/dev/null; then
        GATEWAY_BASE_URL="http://127.0.0.1:${GATEWAY_PORT}/v1"
        echo "[+] Gateway :${GATEWAY_PORT} healthy — routing via gateway"
    else
        GATEWAY_BASE_URL="http://127.0.0.1:${OLLAMA_PORT}/v1"
        [[ "$(_oc_cfg_get gateway_enabled)" == "true" ]] && \
            echo "[!] Gateway :${GATEWAY_PORT} unreachable — falling back to :${OLLAMA_PORT}"
    fi
    printf 'export OPENAI_BASE_URL=%s\n' "$GATEWAY_BASE_URL" >> /tmp/.oc-launch.sh
else
    printf 'export OPENAI_BASE_URL=%s\n' "$OPENAI_BASE_URL" >> /tmp/.oc-launch.sh
fi

# Extra headers from config
HEADERS_JSON=$(_oc_cfg_get_json "openai_extra_headers")
if [[ "$HEADERS_JSON" != "{}" && "$HEADERS_JSON" != "null" ]]; then
    printf "export OPENAI_EXTRA_HEADERS='%s'\n" "$HEADERS_JSON" >> /tmp/.oc-launch.sh
fi

printf "export OPENAI_MODEL='%s'\n" "$MODEL" >> /tmp/.oc-launch.sh

# If route system switched to Anthropic provider, pass that through
if [[ "${CLAUDE_CODE_USE_OPENAI:-1}" == "0" ]]; then
    printf 'export CLAUDE_CODE_USE_OPENAI=0\n' >> /tmp/.oc-launch.sh
    printf 'export ANTHROPIC_API_KEY=%s\n' "${ANTHROPIC_API_KEY:-}" >> /tmp/.oc-launch.sh
fi

printf 'echo "super-oc-cli (%s)"\n' "$MODEL" >> /tmp/.oc-launch.sh

# ── Append execution mode ───────────────────────────────────────────────────
if [[ "$USE_PIPELINE" == true ]]; then
    cat >> /tmp/.oc-launch.sh << PIPELINE
OC_LIB="${OC_LIB_DIR}"
source "\$OC_LIB/oc-engine.sh"
source "\$OC_LIB/oc-routes.sh"
source "\$OC_LIB/oc-agents.sh"
source "\$OC_LIB/oc-epochs.sh"
source "\$OC_LIB/oc-compaction.sh"
source "\$OC_LIB/oc-permissions.sh"
source "\$OC_LIB/oc-tools.sh"
source "\$OC_LIB/oc-cost.sh"
oc_agent_init
ocp_init
occ_init "\$CLAUDE_SESSION_ID"
oc_epoch_init "\$CLAUDE_SESSION_ID"
PIPELINE

    if [[ -n "$AGENT_NAME" ]]; then
        printf 'oc_agent_select "%s"\n' "$AGENT_NAME" >> /tmp/.oc-launch.sh
    fi

    cat >> /tmp/.oc-launch.sh << 'ENGINE'
echo "[oc-engine] Starting agentic pipeline..."
oc_engine_init "$CLAUDE_SESSION_ID" "$HOME/.openclaude/pipeline.json"
oc_engine_run
ENGINE_RC=$?
occ_session_summary
if [[ $ENGINE_RC -eq 0 ]]; then
    echo "[oc-engine] Pipeline completed successfully."
else
    echo "[oc-engine] Pipeline exited with code $ENGINE_RC"
fi
ENGINE

else
    cat >> /tmp/.oc-launch.sh << WATCHDOG
OC_LIB="${OC_LIB_DIR}"
if [[ -f "\$OC_LIB/oc-cost.sh" ]]; then
    source "\$OC_LIB/oc-cost.sh"
    occ_init "\$CLAUDE_SESSION_ID"
fi
while true; do
    openclaude ${OC_FLAGS}
    EC=\$?
    [ \$EC -eq 0 ] && break
    echo "[\$(date)] OpenClaude exited with code \$EC — restarting in 3s..." | tee -a /tmp/openclaude-crashes.log
    sleep 3
done
if declare -f occ_session_summary &>/dev/null; then
    occ_session_summary
fi
WATCHDOG
fi

# ── Dry run: show script and exit ───────────────────────────────────────────
if [[ "$USE_DRY_RUN" == true ]]; then
    echo ""
    echo "=== DRY RUN — generated launch script ==="
    cat /tmp/.oc-launch.sh
    echo "=== END ==="
    echo ""
    echo "Model: $MODEL | Session: $SESSION | Mode: $([ "$USE_PIPELINE" == true ] && echo pipeline || echo interactive)"
    _oc_cfg_dump
    exit 0
fi

# ── Launch ───────────────────────────────────────────────────────────────────
MODE_LABEL="interactive"
[[ "$USE_PIPELINE" == true ]] && MODE_LABEL="pipeline"
echo "Launching super-oc-cli ($MODEL) in tmux session '$SESSION' [mode: $MODE_LABEL]"
exec tmux new-session -s "$SESSION" "bash /tmp/.oc-launch.sh"
